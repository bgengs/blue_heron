# --- secrets (never commit) ---
.env
book/.env
web/config.local.php

# --- book pipeline runtime ---
book/logs/
book/state/DONE
book/.venv/

# --- large / generated assets (regenerable, don't belong in git) ---
source_photos/
resized/
output/

# Full-res camera originals + Photoshop exports (Process reads these locally)
raw/*
!raw/.gitkeep

# Published gallery derivatives (written by studio Publish; deploy separately)
web/images/web/*
web/images/thumb/*
!web/images/web/.gitkeep
!web/images/thumb/.gitkeep

# large binary source types anywhere (Photoshop, JPEG XL)
*.psb
*.psd
*.jxl

# --- legacy static site (superseded by PHP web/) ---
/site/

# --- databases / studio state ---
data/orders.db
web/storage/orders.db

# --- dependencies ---
web/vendor/
node_modules/
.venv/

# --- python ---
__pycache__/
*.pyc

# --- local editor/tooling ---
.claude/settings.local.json
*.mp4
