# --- secrets (never commit) ---
.env
web/config.local.php

# --- large / generated assets (regenerable, don't belong in git) ---
source_photos/
resized/
output/

# ingest folder — raw originals never go in git (can be tens of GB, incl. .psb/.psd)
raw/*
!raw/.gitkeep

# large binary source types anywhere (Photoshop, JPEG XL)
*.psb
*.psd
*.jxl

# --- legacy static site (superseded by PHP web/) ---
/site/

# --- databases / studio state ---
data/orders.db
web/storage/orders.db

# --- dependencies ---
web/vendor/
node_modules/
.venv/

# --- python ---
__pycache__/
*.pyc

# --- local editor/tooling ---
.claude/settings.local.json
*.mp4
