# Copy to .env and fill in. Never commit .env.

# Admin login (required for /admin)
ADMIN_PASSWORD=pick-a-strong-password
SECRET_KEY=generate-a-long-random-string

# Stripe (test keys start with sk_test_; live with sk_live_)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Public URL of the site (used for Stripe redirect URLs)
SITE_URL=http://127.0.0.1:8807

HOST=127.0.0.1
PORT=8807

# Optional: AI title suggestions from the actual photo (pip install anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
